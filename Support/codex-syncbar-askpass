#!/usr/bin/env bash

set +x
set -euo pipefail

credential_id="${CODEX_SYNCBAR_CREDENTIAL_ID:-${CODEX_SYNCBAR_DEVICE_ID:-}}"
secret_kind="${CODEX_SYNCBAR_SECRET_KIND:-}"
security_bin="${CODEX_SYNCBAR_SECURITY_BIN:-/usr/bin/security}"

case "$credential_id" in ''|*[!A-Za-z0-9-]*|-*) exit 1 ;; esac
case "$secret_kind" in password|passphrase) ;; *) exit 1 ;; esac

exec "$security_bin" find-generic-password \
  -s com.sunggu.codexsyncbar.ssh \
  -a "$credential_id.$secret_kind" \
  -w
