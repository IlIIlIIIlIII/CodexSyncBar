[ ! -e "$new/.local/bin/gpt-switch" ] || { [ -f "$new/.local/bin/gpt-switch" ] && [ ! -L "$new/.local/bin/gpt-switch" ]; }
[ ! -e "$new/.local/lib/gpt-switch/codex-syncbar-askpass" ] || { [ -f "$new/.local/lib/gpt-switch/codex-syncbar-askpass" ] && [ ! -L "$new/.local/lib/gpt-switch/codex-syncbar-askpass" ]; }
[ ! -e "$new/.local/lib/gpt-switch/usage-summary.mjs" ] || { [ -f "$new/.local/lib/gpt-switch/usage-summary.mjs" ] && [ ! -L "$new/.local/lib/gpt-switch/usage-summary.mjs" ]; }
[ ! -e "$new/.local/share/gpt-switch" ] || { [ -d "$new/.local/share/gpt-switch" ] && [ ! -L "$new/.local/share/gpt-switch" ]; }
[ ! -e "$new/.codex/auth.json" ] || { [ -f "$new/.codex/auth.json" ] && [ ! -L "$new/.codex/auth.json" ]; }
[ -z "$(find "$new" ! -type d ! -type f -print -quit)" ]

ensure_parent() {
  parent="$1"
  if path_exists "$parent"; then
    [ -d "$parent" ] && [ ! -L "$parent" ]
  else
    mkdir "$parent"
  fi
}
ensure_parent "$HOME/.local"
ensure_parent "$HOME/.local/bin"
ensure_parent "$HOME/.local/lib"
ensure_parent "$HOME/.local/lib/gpt-switch"
ensure_parent "$HOME/.local/share"
ensure_parent "$HOME/.codex"

if path_exists "$helper"; then mv "$helper" "$old/helper"; old_helper=1; fi
if path_exists "$askpass"; then mv "$askpass" "$old/askpass"; old_askpass=1; fi
if path_exists "$usage"; then mv "$usage" "$old/usage"; old_usage=1; fi
if path_exists "$state"; then mv "$state" "$old/state"; old_state=1; fi
if path_exists "$auth"; then mv "$auth" "$old/auth"; old_auth=1; fi

if path_exists "$new/.local/bin/gpt-switch"; then mv "$new/.local/bin/gpt-switch" "$helper"; new_helper=1; fi
if path_exists "$new/.local/lib/gpt-switch/codex-syncbar-askpass"; then mv "$new/.local/lib/gpt-switch/codex-syncbar-askpass" "$askpass"; new_askpass=1; fi
if path_exists "$new/.local/lib/gpt-switch/usage-summary.mjs"; then mv "$new/.local/lib/gpt-switch/usage-summary.mjs" "$usage"; new_usage=1; fi
if path_exists "$new/.local/share/gpt-switch"; then mv "$new/.local/share/gpt-switch" "$state"; new_state=1; fi
if path_exists "$new/.codex/auth.json"; then mv "$new/.codex/auth.json" "$auth"; new_auth=1; fi

[ "$new_helper" -eq 0 ] || { [ -f "$helper" ] && [ ! -L "$helper" ]; }
[ "$new_askpass" -eq 0 ] || { [ -f "$askpass" ] && [ ! -L "$askpass" ]; }
[ "$new_usage" -eq 0 ] || { [ -f "$usage" ] && [ ! -L "$usage" ]; }
[ "$new_state" -eq 0 ] || { [ -d "$state" ] && [ ! -L "$state" ]; }
[ "$new_auth" -eq 0 ] || { [ -f "$auth" ] && [ ! -L "$auth" ]; }
committed=1
rm -rf "$stage"
trap - EXIT HUP INT TERM'
  remote_ssh "$index" "$command" <"$snapshot"
}

prepare_remote_bootstrap_snapshot() {
  local index="$1"
  local wanted="$2"
  local snapshot temporary command entries verbose entry listing first valid endpoint_fp candidate
  endpoint_fp=$(remote_endpoint_fingerprint "$index") || \
    die "could not bind bootstrap recovery to its SSH endpoint"
  valid_sha256 "$endpoint_fp" || die "invalid SSH endpoint fingerprint"
  snapshot="$STATE_ROOT/.bootstrap-remote-backup.$wanted.$endpoint_fp.tar"

  # A recovery archive may only ever be sent back to the exact endpoint that
  # created it. An archive from an older/unbound format or a changed host is
  # preserved for manual recovery and never uploaded to the new destination.
  for candidate in \
    "$STATE_ROOT"/.bootstrap-remote-backup."$wanted".*.tar \
    "$STATE_ROOT/.bootstrap-remote-backup.$wanted.tar"; do
    if [ ! -e "$candidate" ] && [ ! -L "$candidate" ]; then continue; fi
    [ "$candidate" = "$snapshot" ] || \
      die "bootstrap recovery archive belongs to a different or unbound SSH endpoint; preserved at $candidate"
  done

  if [ -e "$snapshot" ] || [ -L "$snapshot" ]; then
    [ -f "$snapshot" ] && [ ! -L "$snapshot" ] && [ "$(file_mode "$snapshot")" = 600 ] || \
      die "existing bootstrap recovery archive is unsafe: $snapshot"
    if restore_remote_bootstrap_snapshot "$index" "$snapshot"; then
      rm -f "$snapshot"
    else
      die "previous bootstrap recovery is still required; archive preserved at $snapshot"
    fi
  fi

  temporary=$(mktemp "$STATE_ROOT/.bootstrap-remote-backup.$wanted.XXXXXX") || \
    die "could not prepare remote bootstrap recovery"
  chmod 600 "$temporary"
  command='set -eu
cd "$HOME"
set --
for path in .local/bin/gpt-switch .local/lib/gpt-switch/codex-syncbar-askpass .local/lib/gpt-switch/usage-summary.mjs .local/share/gpt-switch .codex/auth.json; do
  if [ -e "$path" ] || [ -L "$path" ]; then set -- "$@" "$path"; fi
done
if [ "$#" -eq 0 ]; then
  COPYFILE_DISABLE=1 tar -cf - -T /dev/null
else
  COPYFILE_DISABLE=1 tar -cf - "$@"
fi'
  if ! remote_ssh "$index" "$command" >"$temporary"; then
    rm -f "$temporary"
    die "could not snapshot the remote device before bootstrap"
  fi
  entries="$temporary.entries"
  verbose="$temporary.verbose"
  if ! tar -tf "$temporary" >"$entries" || ! tar -tvf "$temporary" >"$verbose"; then
    rm -f "$temporary" "$entries" "$verbose"
    die "remote bootstrap recovery archive is unreadable"
  fi
  valid=1
  while IFS= read -r entry || [ -n "$entry" ]; do
    case "$entry" in
      ''|/*|*..*|*//*|./*|*/./*|*[!A-Za-z0-9._/-]*) valid=0; break ;;
    esac
    case "$entry" in
      .local/bin/gpt-switch|.local/lib/gpt-switch/codex-syncbar-askpass|\
      .local/share/gpt-switch|.local/share/gpt-switch/*|.codex/auth.json) ;;
      *) valid=0; break ;;
    esac
  done <"$entries"
  if [ "$valid" -eq 1 ]; then
    while IFS= read -r listing || [ -n "$listing" ]; do
      [ -n "$listing" ] || { valid=0; break; }
      first=${listing%"${listing#?}"}
      case "$first" in d|-) ;; *) valid=0; break ;; esac
    done <"$verbose"
  fi
  if [ "$valid" -eq 1 ] && \
     { [ "$(wc -l <"$entries" | tr -d ' ')" != "$(wc -l <"$verbose" | tr -d ' ')" ] || \
       [ -n "$(sort "$entries" | uniq -d)" ]; }; then
    valid=0
  fi
  rm -f "$entries" "$verbose"
  if [ "$valid" -ne 1 ]; then
    rm -f "$temporary"
    die "remote bootstrap recovery archive contains unsafe paths or file types"
  fi
  mv -f "$temporary" "$snapshot"
  chmod 600 "$snapshot"
  BOOTSTRAP_REMOTE_INDEX="$index"
  BOOTSTRAP_REMOTE_SNAPSHOT="$snapshot"
  BOOTSTRAP_ROLLBACK_NEEDED=1
}

rollback_remote_bootstrap_in_progress() {
  [ "$BOOTSTRAP_ROLLBACK_NEEDED" -eq 1 ] || return 0
  warn "device bootstrap did not complete; restoring its previous helper and account state"
  if restore_remote_bootstrap_snapshot "$BOOTSTRAP_REMOTE_INDEX" "$BOOTSTRAP_REMOTE_SNAPSHOT"; then
    rm -f "$BOOTSTRAP_REMOTE_SNAPSHOT"
    BOOTSTRAP_ROLLBACK_NEEDED=0
    BOOTSTRAP_REMOTE_INDEX=-1
    BOOTSTRAP_REMOTE_SNAPSHOT=""
    return 0
  fi
  warn "bootstrap rollback failed; recovery archive preserved at $BOOTSTRAP_REMOTE_SNAPSHOT"
  return 1
}

commit_remote_bootstrap_snapshot() {
  [ "$BOOTSTRAP_ROLLBACK_NEEDED" -eq 1 ] || return 0
  rm -f "$BOOTSTRAP_REMOTE_SNAPSHOT" || return 1
  BOOTSTRAP_ROLLBACK_NEEDED=0
  BOOTSTRAP_REMOTE_INDEX=-1
  BOOTSTRAP_REMOTE_SNAPSHOT=""
}

remote_node() {
  local index="$1"
  local action="$2"
  local argument="${3:-}"
  local command="$REMOTE_BIN __node $action"
  if [ -n "$argument" ]; then
    command="$command $argument"
  fi
  remote_ssh "$index" "$command"
}

remote_node_file() {
  local index="$1"
  local source="$2"
  local action="$3"
  shift 3
  local command="$REMOTE_BIN __node $action"
  local argument
  for argument in "$@"; do
    case "$argument" in
      ''|*[!0-9a-zA-Z_-]*) die "unsafe internal remote argument" ;;
    esac
    command="$command $argument"
  done
  remote_ssh "$index" "$command" <"$source"
}

remote_node_args() {
  local index="$1"
  local action="$2"
  shift 2
  local command="$REMOTE_BIN __node $action"
  local argument
  for argument in "$@"; do
    case "$argument" in
      ''|*[!0-9a-zA-Z_-]*) die "unsafe internal remote argument" ;;
    esac
    command="$command $argument"
  done
  remote_ssh "$index" "$command"
}

field_value() {
  local line="$1"
  local wanted="$2"
  local field
  for field in $line; do
    case "$field" in
      "$wanted"=*) printf '%s\n' "${field#*=}"; return 0 ;;
    esac
  done
  return 1
}

rollback_switches() {
  local local_previous="$1"
  local local_changed="$2"
  local remote_count="$3"
  local restart_apps="$4"
  shift 4
  local remote_previous=("$@")
  local index

  warn "switch failed; rolling back changed nodes"
  if [ "$local_changed" -eq 1 ]; then
    "$0" __node switch "$local_previous" "$restart_apps" >/dev/null || warn "local rollback failed"
  fi
  index=$((remote_count - 1))
  while [ "$index" -ge 0 ]; do
    remote_node "$index" switch "${remote_previous[$index]}" "$restart_apps" >/dev/null || warn "rollback failed on ${REMOTE_LABELS[$index]}"
    index=$((index - 1))
  done
}

require_refresh_helper() {
  local mode
  command -v "$NODE_BIN" >/dev/null 2>&1 || die "Node.js is required for credential refresh"
  [ -f "$REFRESH_HELPER" ] || die "refresh helper is missing: $REFRESH_HELPER"
  [ ! -L "$REFRESH_HELPER" ] || die "refusing symlinked refresh helper: $REFRESH_HELPER"
  [ "$(file_owner_id "$REFRESH_HELPER")" = "$(id -u)" ] || die "refresh helper has the wrong owner"
  mode=$(file_mode "$REFRESH_HELPER")
  case "$mode" in 500|700) ;; *) die "refresh helper must have mode 500 or 700" ;; esac
}

helper_inspect() {
  local file="$1"
  local kind="${2:-either}"
  "$NODE_BIN" "$REFRESH_HELPER" inspect "$file" "$kind"
}

metadata_field() {
  local metadata="$1"
  local field="$2"
  printf '%s' "$metadata" | jq -er --arg field "$field" '.[$field] | select(. != null)'
}

pending_path() {
  printf '%s/%s.%s\n' "$PENDING_DIR" "$1" "$2"
}

mark_pending() {
  local profile="$1"
  local label="$2"
  local access_fp="$3"
  local destination temporary
  destination=$(pending_path "$profile" "$label")
  temporary=$(mktemp "$PENDING_DIR/.pending.XXXXXX")
  if ! printf 'profile=%s node=%s access_fp=%s updated_at=%s\n' \
    "$profile" "$label" "$access_fp" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >"$temporary"; then
    rm -f "$temporary"
    return 1
  fi
  chmod 600 "$temporary"
  mv -f "$temporary" "$destination"
}

clear_pending() {
  rm -f "$(pending_path "$1" "$2")"
}

profile_has_pending() {
  local profile="$1"
  local label
  for label in "${REMOTE_LABELS[@]}"; do
    [ ! -f "$(pending_path "$profile" "$label")" ] || return 0
  done
  return 1
}

ensure_refresh_apps_stopped() {
  [ "$REFRESH_APPS_STOPPED" -eq 0 ] || return 0
  [ "$REFRESH_RESTART_APPS" -eq 1 ] || die "active-profile refresh requires stopping desktop clients"
  running_inside_desktop_app && die "run credential refresh outside the ChatGPT/Codex desktop app"
  REFRESH_APP_STATE=$(stop_local_apps) || die "could not stop local desktop clients"
  REFRESH_APPS_STOPPED=1
}

finish_refresh_apps() {
  if [ "$REFRESH_APPS_STOPPED" -eq 1 ]; then
    start_local_apps "$REFRESH_APP_STATE"
    REFRESH_APPS_STOPPED=0
    REFRESH_APP_STATE="none"
  fi
}

reconcile_active_full_profile() {
  local profile="$1"
  local profile_file active canonical live canonical_account live_account
  local canonical_access live_access canonical_refresh live_refresh canonical_time live_time
  profile_file=$(profile_path "$profile")
  active=$(detect_active_profile 2>/dev/null || true)
  [ "$active" = "$profile" ] || return 0
  validate_secure_auth_file "$profile_file" full || die "MacBook profile $profile is not full auth"
  validate_secure_auth_file "$AUTH_FILE" full || die "active MacBook auth is not full auth"

  canonical=$(helper_inspect "$profile_file" full) || die "could not inspect profile $profile"
  live=$(helper_inspect "$AUTH_FILE" full) || die "could not inspect active auth"
  canonical_account=$(metadata_field "$canonical" accountFingerprint)
  live_account=$(metadata_field "$live" accountFingerprint)
  [ "$canonical_account" = "$live_account" ] || die "active auth account does not match profile $profile"
  canonical_access=$(metadata_field "$canonical" accessFingerprint)
  live_access=$(metadata_field "$live" accessFingerprint)
  canonical_refresh=$(metadata_field "$canonical" refreshFingerprint)
  live_refresh=$(metadata_field "$live" refreshFingerprint)
  if [ "$canonical_access" = "$live_access" ] && [ "$canonical_refresh" = "$live_refresh" ]; then
    return 0
  fi

  ensure_refresh_apps_stopped
  canonical=$(helper_inspect "$profile_file" full) || die "could not re-read profile $profile"
  live=$(helper_inspect "$AUTH_FILE" full) || die "could not re-read active auth"
  canonical_time=$(metadata_field "$canonical" lastRefreshEpoch 2>/dev/null || metadata_field "$canonical" expiresAt)
  live_time=$(metadata_field "$live" lastRefreshEpoch 2>/dev/null || metadata_field "$live" expiresAt)
  if [ "$live_time" -gt "$canonical_time" ]; then
    atomic_copy "$AUTH_FILE" "$profile_file" || die "could not capture newer active credentials"
  else
    atomic_copy "$profile_file" "$AUTH_FILE" || die "could not reconcile active credentials"
  fi
}

promote_refreshed_auth() {
  local profile="$1"
  local staged="$2"
  local profile_file active staged_meta current_meta staged_account current_account
  profile_file=$(profile_path "$profile")
  validate_secure_auth_file "$staged" full || return 1
  staged_meta=$(helper_inspect "$staged" full) || return 1
  current_meta=$(helper_inspect "$profile_file" full) || return 1
  staged_account=$(metadata_field "$staged_meta" accountFingerprint) || return 1
  current_account=$(metadata_field "$current_meta" accountFingerprint) || return 1
  [ "$staged_account" = "$current_account" ] || return 1
  [ "$(metadata_field "$staged_meta" remainingSeconds)" -gt 0 ] || return 1

  active=$(detect_active_profile 2>/dev/null || true)
  if [ "$active" = "$profile" ]; then
    ensure_refresh_apps_stopped
  fi
  atomic_copy "$staged" "$profile_file" || return 1
  if [ "$active" = "$profile" ]; then
    atomic_copy "$profile_file" "$AUTH_FILE" || return 1
    atomic_write_current "$profile" || return 1
  fi
}

recover_refresh_transaction() {
  local profile="$1"
  local transaction staged before staged_meta before_meta changed current_meta
  local staged_account current_account staged_time current_time
  for transaction in "$REFRESH_TXN_DIR/$profile."*; do
    [ -d "$transaction" ] || continue
    staged="$transaction/codex/auth.json"
    before="$transaction/before.json"
    if ! validate_secure_auth_file "$staged" full || [ ! -s "$before" ]; then
      rm -rf "$transaction"
      continue
    fi
    staged_meta=$(helper_inspect "$staged" full 2>/dev/null || true)
    before_meta=$(cat "$before" 2>/dev/null || true)
    [ -n "$staged_meta" ] && [ -n "$before_meta" ] || continue
    changed=0
    if [ "$(metadata_field "$staged_meta" accessFingerprint 2>/dev/null || true)" != "$(metadata_field "$before_meta" accessFingerprint 2>/dev/null || true)" ] || \
       [ "$(metadata_field "$staged_meta" refreshFingerprint 2>/dev/null || true)" != "$(metadata_field "$before_meta" refreshFingerprint 2>/dev/null || true)" ]; then
      changed=1
    fi
    if [ "$changed" -eq 0 ]; then
      rm -rf "$transaction"
      continue
    fi

    current_meta=$(helper_inspect "$(profile_path "$profile")" full 2>/dev/null || true)
    [ -n "$current_meta" ] || continue
    staged_account=$(metadata_field "$staged_meta" accountFingerprint 2>/dev/null || true)
    current_account=$(metadata_field "$current_meta" accountFingerprint 2>/dev/null || true)
    staged_time=$(metadata_field "$staged_meta" lastRefreshEpoch 2>/dev/null || metadata_field "$staged_meta" expiresAt 2>/dev/null || printf '0')
    current_time=$(metadata_field "$current_meta" lastRefreshEpoch 2>/dev/null || metadata_field "$current_meta" expiresAt 2>/dev/null || printf '0')
    if [ "$staged_account" = "$current_account" ] && [ "$staged_time" -ge "$current_time" ]; then
      if promote_refreshed_auth "$profile" "$staged"; then
        rm -rf "$transaction"
      fi
    elif [ "$staged_account" = "$current_account" ]; then
      rm -rf "$transaction"
    fi
  done
}

refresh_profile_canonical() {
  local profile="$1"
  local profile_file transaction before_result staged_meta before_meta
  profile_file=$(profile_path "$profile")
  validate_secure_auth_file "$profile_file" full || return 1
  transaction=$(mktemp -d "$REFRESH_TXN_DIR/$profile.XXXXXX") || return 1
  chmod 700 "$transaction"
  mkdir -m 700 "$transaction/codex"
  atomic_copy "$profile_file" "$transaction/codex/auth.json" || {
    rm -rf "$transaction"
    return 1
  }
  before_result=$(helper_inspect "$transaction/codex/auth.json" full) || {
    rm -rf "$transaction"
    return 1
  }
  if ! printf '%s\n' "$before_result" >"$transaction/before.json" || ! chmod 600 "$transaction/before.json"; then
    rm -rf "$transaction"
    return 1
  fi
  if ! "$NODE_BIN" "$REFRESH_HELPER" refresh "$transaction/codex" >"$transaction/result.json"; then
    staged_meta=$(helper_inspect "$transaction/codex/auth.json" full 2>/dev/null || true)
    before_meta=$(cat "$transaction/before.json" 2>/dev/null || true)
    if [ -z "$staged_meta" ] || \
       { [ "$(metadata_field "$staged_meta" accessFingerprint 2>/dev/null || true)" = "$(metadata_field "$before_meta" accessFingerprint 2>/dev/null || true)" ] && \
         [ "$(metadata_field "$staged_meta" refreshFingerprint 2>/dev/null || true)" = "$(metadata_field "$before_meta" refreshFingerprint 2>/dev/null || true)" ]; }; then
      rm -rf "$transaction"
    fi
    return 1
  fi
  chmod 600 "$transaction/result.json"
  if ! promote_refreshed_auth "$profile" "$transaction/codex/auth.json"; then
    return 1
  fi
  rm -rf "$transaction"
}

SYNC_SYNCED_COUNT=0
SYNC_PENDING_COUNT=0

sync_profile_access() {
  local profile="$1"
  local profile_file temporary metadata account_fp access_fp index label
  SYNC_SYNCED_COUNT=0
  SYNC_PENDING_COUNT=${#REMOTE_TARGETS[@]}
  profile_file=$(profile_path "$profile")
  validate_secure_auth_file "$profile_file" full || return 1
  metadata=$(helper_inspect "$profile_file" full) || return 1
  account_fp=$(metadata_field "$metadata" accountFingerprint) || return 1
  access_fp=$(metadata_field "$metadata" accessFingerprint) || return 1
  temporary=$(mktemp "$STATE_ROOT/.access-only.$profile.XXXXXX") || return 1
  chmod 600 "$temporary"
  if ! "$NODE_BIN" "$REFRESH_HELPER" sanitize "$profile_file" "$temporary" >/dev/null; then
    rm -f "$temporary"
    return 1
  fi
  validate_secure_auth_file "$temporary" access-only || {
    rm -f "$temporary"
    return 1
  }

  SYNC_SYNCED_COUNT=0
  SYNC_PENDING_COUNT=0
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    label="${REMOTE_LABELS[$index]}"
    if remote_node_file "$index" "$temporary" install-access "$profile" "$account_fp" "$access_fp" >/dev/null 2>&1 || \
       { remote_node_args "$index" stop-clients >/dev/null 2>&1 && \
         remote_node_args "$index" inspect-access "$profile" "$access_fp" >/dev/null 2>&1; }; then
      SYNC_SYNCED_COUNT=$((SYNC_SYNCED_COUNT + 1))
      clear_pending "$profile" "$label"
    else
      mark_pending "$profile" "$label" "$access_fp" || true
      SYNC_PENDING_COUNT=$((SYNC_PENDING_COUNT + 1))
    fi
    index=$((index + 1))
  done
  rm -f "$temporary"
  [ "$SYNC_PENDING_COUNT" -eq 0 ]
}

controller_import_login() {
  local profile="$1"
  local replace_account="$2"
  local incoming transaction building suffix profile_file active="" active_flag=0
  local incoming_meta existing_meta incoming_account existing_account
  local other_profile other_file other_meta other_account
  local incoming_access actual_meta actual_account actual_access remaining label
  local incoming_sha profile_backup_sha="none" active_backup_sha="none" current_backup_sha="none"

  validate_profile_name "$profile"
  case "$replace_account" in 0|1) ;; *) die "invalid account replacement flag" ;; esac
  require_refresh_helper
  acquire_controller_lock
  controller_recover_login_transactions >/dev/null || die "an interrupted login import must be recovered before importing another login"
  controller_recover_logout_intents >/dev/null || die "an interrupted logout operation must be recovered before importing a login"
  acquire_lock

  building=$(mktemp -d "$STATE_ROOT/.login-building.$profile.XXXXXX") || die "could not create login transaction"
  chmod 700 "$building"
  write_login_transaction_manifest "$building" collecting "$profile" || {
    rm -rf "$building"
    die "could not initialize durable login transaction"
  }
  suffix=${building##*.login-building.$profile.}
  transaction="$LOGIN_TXN_DIR/$profile.$suffix"
  if ! mv "$building" "$transaction"; then
    rm -rf "$building"
    die "could not activate durable login transaction"
  fi
  LOGIN_BACKUP_DIR="$transaction"
  incoming="$transaction/incoming.auth.json"
  if ! cat >"$incoming" || ! chmod 600 "$incoming"; then
    rm -rf "$transaction"
    die "could not receive login credentials"
  fi
  validate_secure_auth_file "$incoming" full || {
    rm -rf "$transaction"
    die "received login credentials are not valid full Codex auth"
  }
  incoming_meta=$(helper_inspect "$incoming" full) || {
    rm -rf "$transaction"
    die "received login credentials failed token inspection"
  }
  remaining=$(metadata_field "$incoming_meta" remainingSeconds) || {
    rm -rf "$transaction"
    die "received login credentials have no expiry metadata"
  }
  [ "$remaining" -gt 0 ] || {
    rm -rf "$transaction"
    die "received login credentials are already expired"
  }
  incoming_account=$(metadata_field "$incoming_meta" accountFingerprint) || die "could not identify logged-in account"
  incoming_access=$(metadata_field "$incoming_meta" accessFingerprint) || die "could not identify logged-in access token"

  for other_profile in $(list_profile_ids); do
    [ "$other_profile" != "$profile" ] || continue
    other_file=$(profile_path "$other_profile")
    if [ -e "$other_file" ]; then
      validate_secure_auth_file "$other_file" full || die "existing profile $other_profile is insecure or invalid"
      other_meta=$(helper_inspect "$other_file" full) || die "could not inspect existing profile $other_profile"
      other_account=$(metadata_field "$other_meta" accountFingerprint) || die "could not identify existing profile $other_profile"
      if [ "$other_account" = "$incoming_account" ]; then
        die "logged-in account is already assigned to profile $other_profile; choose a different account"
      fi
    fi
  done

  profile_file=$(profile_path "$profile")
  LOGIN_PROFILE_EXISTED=0
  LOGIN_CURRENT_EXISTED=0
  if [ -e "$profile_file" ]; then
    validate_secure_auth_file "$profile_file" full || die "existing profile $profile is insecure or invalid"
    existing_meta=$(helper_inspect "$profile_file" full) || die "could not inspect existing profile $profile"
    existing_account=$(metadata_field "$existing_meta" accountFingerprint) || die "could not identify existing profile $profile"
    if [ "$existing_account" != "$incoming_account" ] && [ "$replace_account" -ne 1 ]; then
      die "logged-in account does not match profile $profile; explicit replacement is required"
    fi
    atomic_copy "$profile_file" "$transaction/profile.auth.json" || die "could not back up profile $profile"
    LOGIN_PROFILE_EXISTED=1
    profile_backup_sha=$(sha256_file "$transaction/profile.auth.json") || die "could not inspect profile backup"
  fi

  if [ -e "$AUTH_FILE" ]; then
    active=$(detect_active_profile) || die "cannot identify the active Mac profile before login import"
  fi
  if [ "$active" = "$profile" ]; then
    active_flag=1
    validate_secure_auth_file "$AUTH_FILE" full || die "active Mac auth is insecure or invalid"
    atomic_copy "$AUTH_FILE" "$transaction/active.auth.json" || die "could not back up active Mac auth"
    active_backup_sha=$(sha256_file "$transaction/active.auth.json") || die "could not inspect active auth backup"
    if [ -e "$CURRENT_FILE" ]; then
      [ ! -L "$CURRENT_FILE" ] && [ -f "$CURRENT_FILE" ] || die "current profile marker is insecure"
      atomic_copy "$CURRENT_FILE" "$transaction/current" || die "could not back up current profile marker"
      LOGIN_CURRENT_EXISTED=1
      current_backup_sha=$(sha256_file "$transaction/current") || die "could not inspect current marker backup"
    else
      LOGIN_CURRENT_EXISTED=0
    fi
  fi

  incoming_sha=$(sha256_file "$incoming") || die "could not inspect incoming login credentials"
  LOGIN_PROFILE_FILE="$profile_file"
  LOGIN_ACTIVE_FLAG="$active_flag"
  LOGIN_ROLLBACK_NEEDED=1
  write_login_transaction_manifest "$transaction" prepared "$profile" "$LOGIN_PROFILE_EXISTED" \
    "$LOGIN_ACTIVE_FLAG" "$LOGIN_CURRENT_EXISTED" "$incoming_sha" "$profile_backup_sha" \
    "$active_backup_sha" "$current_backup_sha" || die "could not prepare durable login transaction"

  atomic_copy "$incoming" "$profile_file" || die "could not install logged-in profile $profile"
  if [ "$active_flag" -eq 1 ]; then
    atomic_copy "$incoming" "$AUTH_FILE" || die "could not install active Mac auth"
    atomic_write_current "$profile" || die "could not update the current profile marker"
  fi

  validate_secure_auth_file "$profile_file" full || die "installed profile failed security validation"
  actual_meta=$(helper_inspect "$profile_file" full) || die "installed profile failed token inspection"
  actual_account=$(metadata_field "$actual_meta" accountFingerprint) || die "installed profile has no account fingerprint"
  actual_access=$(metadata_field "$actual_meta" accessFingerprint) || die "installed profile has no access fingerprint"
  [ "$actual_account" = "$incoming_account" ] || die "installed profile account verification failed"
  [ "$actual_access" = "$incoming_access" ] || die "installed profile access verification failed"
  if [ "$active_flag" -eq 1 ]; then
    validate_secure_auth_file "$AUTH_FILE" full || die "installed active auth failed security validation"
    [ "$(fingerprint "$AUTH_FILE")" = "$(fingerprint "$profile_file")" ] || die "active account verification failed"
    [ "$(token_fingerprint "$AUTH_FILE")" = "$incoming_access" ] || die "active access verification failed"
  fi

  for label in "${REMOTE_LABELS[@]}"; do
    mark_pending "$profile" "$label" "$incoming_access" || warn "could not mark $label for login sync"
  done
  write_login_transaction_manifest "$transaction" committed "$profile" "$LOGIN_PROFILE_EXISTED" \
    "$LOGIN_ACTIVE_FLAG" "$LOGIN_CURRENT_EXISTED" "$incoming_sha" "$profile_backup_sha" \
    "$active_backup_sha" "$current_backup_sha" || die "could not commit durable login transaction"
  LOGIN_ROLLBACK_NEEDED=0
  rm -rf "$transaction"
  LOGIN_BACKUP_DIR=""
  release_lock
  release_controller_lock
  trap - EXIT HUP INT TERM
  printf 'profile=%s active=%s account=%s access_fp=%s state=imported\n' \
    "$profile" "$active_flag" "$incoming_account" "$incoming_access"
}

controller_refresh_profile() {
  local profile="$1"
  local mode="$2"
  local threshold="$3"
  local profile_file metadata remaining expires_at action="noop" result="ok" active should_sync=0
  validate_profile_name "$profile"
  SYNC_SYNCED_COUNT=0
  SYNC_PENDING_COUNT=0
  profile_file=$(profile_path "$profile")
  if [ ! -e "$profile_file" ]; then
    for label in "${REMOTE_LABELS[@]}"; do clear_pending "$profile" "$label"; done
    SYNC_SYNCED_COUNT=0
    SYNC_PENDING_COUNT=0
    printf 'profile=%s action=missing expires_at=unknown remaining_seconds=unknown local=ok synced=0 pending=0 result=ok\n' "$profile"
    return 0
  fi
  validate_secure_auth_file "$profile_file" full || {
    SYNC_SYNCED_COUNT=0
    SYNC_PENDING_COUNT=${#REMOTE_TARGETS[@]}
    printf 'profile=%s action=none expires_at=unknown remaining_seconds=unknown local=failed synced=0 pending=%s result=failed\n' \
      "$profile" "$SYNC_PENDING_COUNT"
    return 1
  }

  recover_refresh_transaction "$profile"
  reconcile_active_full_profile "$profile"
  metadata=$(helper_inspect "$profile_file" full) || return 1
  remaining=$(metadata_field "$metadata" remainingSeconds) || return 1
  expires_at=$(metadata_field "$metadata" expiresAt) || return 1

  if [ "$mode" = force ] || { [ "$mode" = if-needed ] && [ "$remaining" -le "$threshold" ]; }; then
    active=$(detect_active_profile 2>/dev/null || true)
    [ "$active" != "$profile" ] || ensure_refresh_apps_stopped
    if ! refresh_profile_canonical "$profile"; then
      SYNC_SYNCED_COUNT=0
      SYNC_PENDING_COUNT=${#REMOTE_TARGETS[@]}
      printf 'profile=%s action=refresh-failed expires_at=%s remaining_seconds=%s local=failed synced=0 pending=%s result=failed\n' \
        "$profile" "$expires_at" "$remaining" "$SYNC_PENDING_COUNT"
      return 1
    fi
    action="refreshed"
    metadata=$(helper_inspect "$profile_file" full) || return 1
    remaining=$(metadata_field "$metadata" remainingSeconds) || return 1
    expires_at=$(metadata_field "$metadata" expiresAt) || return 1
  fi

  if [ "$mode" = sync ]; then
    action="synced"
    should_sync=1
  elif [ "$action" = refreshed ] || profile_has_pending "$profile"; then
    should_sync=1
  fi

  if [ "$should_sync" -eq 1 ]; then
    if ! sync_profile_access "$profile"; then
      result="partial"
    fi
  else
    SYNC_SYNCED_COUNT=0
    SYNC_PENDING_COUNT=0
  fi
  printf 'profile=%s action=%s expires_at=%s remaining_seconds=%s local=ok synced=%s pending=%s result=%s\n' \
    "$profile" "$action" "$expires_at" "$remaining" "$SYNC_SYNCED_COUNT" "$SYNC_PENDING_COUNT" "$result"
  [ "$result" = ok ] || return 2
}

controller_refresh_command() {
  local selector="$1"
  local mode="$2"
  local threshold="$3"
  local restart_apps="$4"
  local profile rc=0 profile_rc refreshed=0 pending=0
  [ "$selector" = all ] || validate_profile_name "$selector"
  case "$threshold" in ''|*[!0-9]*) die "threshold must be a non-negative integer" ;; esac
  require_refresh_helper
  REFRESH_RESTART_APPS="$restart_apps"
  acquire_controller_lock
  controller_recover_logout_intents >/dev/null || warn "an interrupted logout operation remains pending"
  controller_cleanup_logout_backups >/dev/null || warn "some completed logout backups remain pending"
  acquire_lock

  for profile in $(list_profile_ids); do
    [ "$selector" = all ] || [ "$selector" = "$profile" ] || continue
    if controller_refresh_profile "$profile" "$mode" "$threshold"; then
      profile_rc=0
    else
      profile_rc=$?
    fi
    if [ "$profile_rc" -eq 1 ]; then
      rc=1
    elif [ "$profile_rc" -eq 2 ] && [ "$rc" -eq 0 ]; then
      rc=2
    fi
    [ "$profile_rc" -eq 0 ] || pending=$((pending + SYNC_PENDING_COUNT))
    [ "$mode" != force ] || [ "$profile_rc" -ne 0 ] || refreshed=$((refreshed + 1))
  done

  finish_refresh_apps
  release_lock
  release_controller_lock
  trap - EXIT HUP INT TERM
  case "$rc" in
    0) printf 'overall=ok pending=0\n' ;;
    2) printf 'overall=partial pending=%s\n' "$pending" ;;
    *) printf 'overall=failed pending=%s\n' "$pending" ;;
  esac
  return "$rc"
}

controller_switch() {
  local target="$1"
  local restart_apps="$2"
  local local_line local_previous local_target_fp line target_fp version index
  local switched_remote=0
  local local_changed=0
  local remote_previous=()
  local expected_fp=""
  local app_state="none"

  validate_profile_name "$target"
  controller_recover_logout_intents >/dev/null || die "an interrupted logout operation must be recovered before switching"
  printf 'Preflight for profile %s...\n' "$target"

  local_line=$("$0" __node preflight "$target") || die "local preflight failed"
  version=$(field_value "$local_line" version) || die "could not parse local helper version"
  [ "$version" = "$SCRIPT_VERSION" ] || die "local helper version mismatch"
  local_previous=$(field_value "$local_line" active) || die "could not parse local preflight"
  local_target_fp=$(field_value "$local_line" target_fp) || die "could not parse local target fingerprint"
  expected_fp="$local_target_fp"

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    line=$(remote_node "$index" preflight "$target") || die "preflight failed on ${REMOTE_LABELS[$index]}"
    version=$(field_value "$line" version) || die "could not parse ${REMOTE_LABELS[$index]} helper version"
    [ "$version" = "$SCRIPT_VERSION" ] || die "helper version mismatch on ${REMOTE_LABELS[$index]}"
    remote_previous[$index]=$(field_value "$line" active) || die "could not parse ${REMOTE_LABELS[$index]} preflight"
    target_fp=$(field_value "$line" target_fp) || die "could not parse ${REMOTE_LABELS[$index]} fingerprint"
    [ "$target_fp" = "$expected_fp" ] || die "profile $target identifies a different account on ${REMOTE_LABELS[$index]}"
    index=$((index + 1))
  done

  if [ "$restart_apps" -eq 1 ]; then
    running_inside_desktop_app && die "run the switch from Terminal.app; restarting the app would terminate this command"
    if ! app_state=$(stop_local_apps); then
      die "could not stop the local desktop app cleanly; no credentials were changed"
    fi
    index=0
    while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
      if ! remote_node "$index" stop-clients >/dev/null; then
        start_local_apps "$app_state"
        die "could not stop clients on ${REMOTE_LABELS[$index]}"
      fi
      index=$((index + 1))
    done
  fi

  printf 'Switching SSH devices...\n'
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if ! remote_node "$index" switch "$target" "$restart_apps" >/dev/null; then
      if remote_node "$index" verify "$target" >/dev/null 2>&1; then
        switched_remote=$((switched_remote + 1))
      else
        if ! remote_node "$index" switch "${remote_previous[$index]}" "$restart_apps" >/dev/null 2>&1; then
          warn "state on ${REMOTE_LABELS[$index]} is uncertain; run '$PROGRAM_NAME status' when it is reachable"
        fi
        rollback_switches "$local_previous" "$local_changed" "$switched_remote" "$restart_apps" "${remote_previous[@]}"
        [ "$restart_apps" -eq 0 ] || start_local_apps "$app_state"
        die "switch failed on ${REMOTE_LABELS[$index]}"
      fi
    else
      switched_remote=$((switched_remote + 1))
    fi
    index=$((index + 1))
  done

  printf 'Switching MacBook...\n'
  if ! "$0" __node switch "$target" "$restart_apps" >/dev/null; then
    if "$0" __node verify "$target" >/dev/null 2>&1; then
      local_changed=1
    else
      if ! "$0" __node switch "$local_previous" "$restart_apps" >/dev/null 2>&1; then
        warn "local state is uncertain; run '$PROGRAM_NAME status'"
      fi
      rollback_switches "$local_previous" "$local_changed" "$switched_remote" "$restart_apps" "${remote_previous[@]}"
      [ "$restart_apps" -eq 0 ] || start_local_apps "$app_state"
      die "local switch failed"
    fi
  else
    local_changed=1
  fi

  printf 'Verifying all nodes...\n'
  if ! "$0" __node verify "$target" >/dev/null; then
    rollback_switches "$local_previous" "$local_changed" "$switched_remote" "$restart_apps" "${remote_previous[@]}"
    [ "$restart_apps" -eq 0 ] || start_local_apps "$app_state"
    die "local verification failed"
  fi
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if ! remote_node "$index" verify "$target" >/dev/null; then
      rollback_switches "$local_previous" "$local_changed" "$switched_remote" "$restart_apps" "${remote_previous[@]}"
      [ "$restart_apps" -eq 0 ] || start_local_apps "$app_state"
      die "verification failed on ${REMOTE_LABELS[$index]}"
    fi
    index=$((index + 1))
  done

  printf 'All %s configured nodes now use profile %s (%s).\n' "$((1 + ${#REMOTE_TARGETS[@]}))" "$target" "$expected_fp"

  if [ "$restart_apps" -eq 1 ]; then
    start_local_apps "$app_state"
  else
    printf 'Existing app processes were not restarted; they may keep the previous account in memory.\n'
  fi
}

profile_map_matches() {
  local line="$1"
  local first_fp="$2"
  local first_access="$3"
  local second_fp="$4"
  local second_access="$5"
  [ "$(field_value "$line" profile1_fp 2>/dev/null || true)" = "$first_fp" ] && \
    [ "$(field_value "$line" profile1_access 2>/dev/null || true)" = "$first_access" ] && \
    [ "$(field_value "$line" profile2_fp 2>/dev/null || true)" = "$second_fp" ] && \
    [ "$(field_value "$line" profile2_access 2>/dev/null || true)" = "$second_access" ]
}

rollback_profile_swaps() {
  local local_changed="$1"
  local remote_count="$2"
  local index
  warn "profile swap failed; restoring previous slot labels"
  if [ "$local_changed" -eq 1 ]; then
    "$0" __node swap-profiles >/dev/null 2>&1 || warn "local profile swap rollback failed"
  fi
  index=$((remote_count - 1))
  while [ "$index" -ge 0 ]; do
    remote_node "$index" swap-profiles >/dev/null 2>&1 || warn "profile swap rollback failed on ${REMOTE_LABELS[$index]}"
    index=$((index - 1))
  done
}

controller_swap_profiles() {
  local local_line line version index
  local first_fp first_access second_fp second_access
  local swapped_remote=0 local_changed=0

  controller_recover_logout_intents >/dev/null || die "an interrupted logout operation must be recovered before swapping profiles"

  profile_has_pending 1 && die "profile 1 still has pending authentication synchronization"
  profile_has_pending 2 && die "profile 2 still has pending authentication synchronization"
  has_refresh_transaction 1 && die "profile 1 has an unfinished refresh transaction"
  has_refresh_transaction 2 && die "profile 2 has an unfinished refresh transaction"

  printf 'Checking profile maps on all configured nodes...\n'
  local_line=$("$0" __node profile-map) || die "could not read the local profile map"
  version=$(field_value "$local_line" version) || die "could not parse local helper version"
  [ "$version" = "$SCRIPT_VERSION" ] || die "local helper version mismatch"
  first_fp=$(field_value "$local_line" profile1_fp) || die "could not identify local profile 1"
  first_access=$(field_value "$local_line" profile1_access) || die "could not identify local profile 1 access"
  second_fp=$(field_value "$local_line" profile2_fp) || die "could not identify local profile 2"
  second_access=$(field_value "$local_line" profile2_access) || die "could not identify local profile 2 access"
  [ "$first_fp" != "$second_fp" ] || die "the two profile slots identify the same account"

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    line=$(remote_node "$index" profile-map) || die "profile map preflight failed on ${REMOTE_LABELS[$index]}"
    version=$(field_value "$line" version) || die "could not parse ${REMOTE_LABELS[$index]} helper version"
    [ "$version" = "$SCRIPT_VERSION" ] || die "helper version mismatch on ${REMOTE_LABELS[$index]}"
    profile_map_matches "$line" "$first_fp" "$first_access" "$second_fp" "$second_access" || \
      die "profile map differs on ${REMOTE_LABELS[$index]}"
    index=$((index + 1))
  done

  printf 'Exchanging profile slots on SSH devices...\n'
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if ! remote_node "$index" swap-profiles >/dev/null; then
      line=$(remote_node "$index" profile-map 2>/dev/null || true)
      if profile_map_matches "$line" "$second_fp" "$second_access" "$first_fp" "$first_access"; then
        swapped_remote=$((swapped_remote + 1))
      else
        rollback_profile_swaps "$local_changed" "$swapped_remote"
        die "profile swap failed on ${REMOTE_LABELS[$index]}"
      fi
    else
      swapped_remote=$((swapped_remote + 1))
    fi
    index=$((index + 1))
  done

  printf 'Exchanging profile slots on MacBook...\n'
  if ! "$0" __node swap-profiles >/dev/null; then
    line=$("$0" __node profile-map 2>/dev/null || true)
    if profile_map_matches "$line" "$second_fp" "$second_access" "$first_fp" "$first_access"; then
      local_changed=1
    else
      rollback_profile_swaps "$local_changed" "$swapped_remote"
      die "local profile swap failed"
    fi
  else
    local_changed=1
  fi

  line=$("$0" __node profile-map) || {
    rollback_profile_swaps "$local_changed" "$swapped_remote"
    die "local profile swap verification failed"
  }
  if ! profile_map_matches "$line" "$second_fp" "$second_access" "$first_fp" "$first_access"; then
    rollback_profile_swaps "$local_changed" "$swapped_remote"
    die "local profile map verification failed"
  fi
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    line=$(remote_node "$index" profile-map 2>/dev/null || true)
    if ! profile_map_matches "$line" "$second_fp" "$second_access" "$first_fp" "$first_access"; then
      rollback_profile_swaps "$local_changed" "$swapped_remote"
      die "profile swap verification failed on ${REMOTE_LABELS[$index]}"
    fi
    index=$((index + 1))
  done

  printf 'profile1=%s profile2=%s state=swapped\n' "$second_fp" "$first_fp"
}

validate_account_fingerprint() {
  local value="$1"
  [ "${#value}" -eq 12 ] || die "account fingerprint must contain 12 hexadecimal characters"
  case "$value" in *[!0-9a-f]*) die "account fingerprint must contain 12 hexadecimal characters" ;; esac
}

profile_map_orientation() {
  local line="$1"
  local first="$2"
  local second="$3"
  local actual_first actual_second
  actual_first=$(field_value "$line" profile1_fp 2>/dev/null || true)
  actual_second=$(field_value "$line" profile2_fp 2>/dev/null || true)
  if [ "$actual_first" = "$first" ] && [ "$actual_second" = "$second" ]; then
    printf 'original\n'
  elif [ "$actual_first" = "$second" ] && [ "$actual_second" = "$first" ]; then
    printf 'swapped\n'
  else
    printf 'unknown\n'
    return 1
  fi
}

controller_reconcile_profile_swap() {
  local first="$1"
  local second="$2"
  local local_line target line orientation index version
  local orientations=()
  validate_account_fingerprint "$first"
  validate_account_fingerprint "$second"
  [ "$first" != "$second" ] || die "profile fingerprints must be distinct"
  controller_recover_logout_intents >/dev/null || die "an interrupted logout operation must be recovered before reconciling profiles"

  local_line=$("$0" __node profile-map) || die "could not read the local profile map for recovery"
  target=$(profile_map_orientation "$local_line" "$first" "$second") || \
    die "local profile map does not match the recovery journal"
  version=$(field_value "$local_line" version) || die "could not parse local helper version"
  [ "$version" = "$SCRIPT_VERSION" ] || die "local helper version mismatch"

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    line=$(remote_node "$index" profile-map) || die "profile recovery preflight failed on ${REMOTE_LABELS[$index]}"
    version=$(field_value "$line" version) || die "could not parse ${REMOTE_LABELS[$index]} helper version"
    [ "$version" = "$SCRIPT_VERSION" ] || die "helper version mismatch on ${REMOTE_LABELS[$index]}"
    orientations[$index]=$(profile_map_orientation "$line" "$first" "$second") || \
      die "profile map on ${REMOTE_LABELS[$index]} does not match the recovery journal"
    index=$((index + 1))
  done

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if [ "${orientations[$index]}" != "$target" ]; then
      remote_node "$index" swap-profiles >/dev/null || \
        die "could not reconcile profile slots on ${REMOTE_LABELS[$index]}"
      line=$(remote_node "$index" profile-map) || die "could not verify profile recovery on ${REMOTE_LABELS[$index]}"
      [ "$(profile_map_orientation "$line" "$first" "$second" 2>/dev/null || true)" = "$target" ] || \
        die "profile recovery verification failed on ${REMOTE_LABELS[$index]}"
    fi
    index=$((index + 1))
  done
  printf 'profile_recovery=%s state=consistent\n' "$target"
}

logout_preflight_matches() {
  local line="$1"
  local target_fp="$2"
  local target_access="$3"
  local fallback_fp="$4"
  local fallback_access="$5"
  [ "$(field_value "$line" target_fp 2>/dev/null || true)" = "$target_fp" ] && \
    [ "$(field_value "$line" target_access 2>/dev/null || true)" = "$target_access" ] && \
    [ "$(field_value "$line" fallback_fp 2>/dev/null || true)" = "$fallback_fp" ] && \
    [ "$(field_value "$line" fallback_access 2>/dev/null || true)" = "$fallback_access" ]
}

logout_recovery_identity_matches() {
  local line="$1"
  local target_fp="$2"
  local fallback_fp="$3"
  [ "$(field_value "$line" target_fp 2>/dev/null || true)" = "$target_fp" ] && \
    [ "$(field_value "$line" fallback_fp 2>/dev/null || true)" = "$fallback_fp" ]
}

controller_recover_logout_intents() {
  local intent operation line state profile fallback target_fp target_access fallback_fp fallback_access
  local index failed rc=0 local_line
  ensure_dirs
  for intent in "$CONTROLLER_TXN_DIR/logout_"*.intent; do
    [ -e "$intent" ] || continue
    if [ ! -f "$intent" ] || [ -L "$intent" ]; then
      warn "invalid controller logout intent: $intent"
      rc=2
      continue
    fi
    operation=${intent##*/}
    operation=${operation%.intent}
    case "$operation" in ''|*[!0-9a-zA-Z_-]*) warn "invalid controller logout operation"; rc=2; continue ;; esac
    line=$(cat "$intent")
    state=$(field_value "$line" state 2>/dev/null || true)
    profile=$(field_value "$line" profile 2>/dev/null || true)
    fallback=$(field_value "$line" fallback 2>/dev/null || true)
    target_fp=$(field_value "$line" target_fp 2>/dev/null || true)
    target_access=$(field_value "$line" target_access 2>/dev/null || true)
    fallback_fp=$(field_value "$line" fallback_fp 2>/dev/null || true)
    fallback_access=$(field_value "$line" fallback_access 2>/dev/null || true)
    if ! valid_profile_pair "$profile" "$fallback"; then
      warn "invalid controller logout intent manifest"
      rc=2
      continue
    fi

    case "$state" in
      staging)
        failed=0
        "$0" __node logout-restore "$operation" "$profile" >/dev/null 2>&1 || failed=1
        index=0
        while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
          remote_node_args "$index" logout-restore "$operation" "$profile" >/dev/null 2>&1 || failed=1
          index=$((index + 1))
        done
        if [ "$failed" -eq 0 ]; then
          local_line=$("$0" __node logout-preflight "$profile" "$fallback" 2>/dev/null || true)
          logout_recovery_identity_matches "$local_line" "$target_fp" "$fallback_fp" || failed=1
          index=0
          while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
            line=$(remote_node_args "$index" logout-preflight "$profile" "$fallback" 2>/dev/null || true)
            logout_recovery_identity_matches "$line" "$target_fp" "$fallback_fp" || failed=1
            index=$((index + 1))
          done
        fi
        if [ "$failed" -eq 0 ]; then
          remove_controller_logout_intent "$operation" || failed=1
        fi
        ;;
      committing)
        failed=0
        "$0" __node logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1 || failed=1
        index=0
        while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
          remote_node_args "$index" logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1 || failed=1
          index=$((index + 1))
        done
        if [ "$failed" -eq 0 ]; then
          index=0
          while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
            remote_node_args "$index" logout-commit "$operation" "$profile" "$fallback" >/dev/null 2>&1 || failed=1
            index=$((index + 1))
          done
          if [ "$failed" -eq 0 ]; then
            "$0" __node logout-commit "$operation" "$profile" "$fallback" >/dev/null 2>&1 || failed=1
          fi
        fi
        if [ "$failed" -eq 0 ]; then
          remove_controller_logout_intent "$operation" || failed=1
        fi
        ;;
      *) failed=1; warn "invalid controller logout intent state" ;;
    esac
    if [ "$failed" -ne 0 ]; then
      warn "controller logout recovery remains pending for $operation"
      rc=2
    fi
  done
  return "$rc"
}

rollback_logout_stages() {
  local operation="$1"
  local profile="$2"
  local local_staged="$3"
  local remote_count="$4"
  local index rc=0
  warn "logout did not complete; restoring the selected profile slot"
  if [ "$local_staged" -eq 1 ]; then
    "$0" __node logout-restore "$operation" "$profile" >/dev/null 2>&1 || { warn "local logout rollback failed"; rc=1; }
  fi
  index=$((remote_count - 1))
  while [ "$index" -ge 0 ]; do
    remote_node_args "$index" logout-restore "$operation" "$profile" >/dev/null 2>&1 || \
      { warn "logout rollback failed on ${REMOTE_LABELS[$index]}"; rc=1; }
    index=$((index - 1))
  done
  return "$rc"
}

abort_logout_stages() {
  local operation="$1"
  local profile="$2"
  local local_staged="$3"
  local remote_count="$4"
  if rollback_logout_stages "$operation" "$profile" "$local_staged" "$remote_count"; then
    remove_controller_logout_intent "$operation" || warn "could not clear recovered controller logout intent"
  else
    warn "controller logout intent was preserved for automatic recovery"
  fi
}

controller_logout_profile() {
  local profile="$1"
  local fallback="${2:-}" local_line line version index operation candidate
  local target_fp target_access fallback_fp fallback_access
  local staged_remote=0 local_staged=0 commit_failed=0
  validate_profile_name "$profile"
  if [ -z "$fallback" ]; then
    for candidate in $(list_profile_ids); do
      [ "$candidate" != "$profile" ] || continue
      if validate_secure_auth_file "$(profile_path "$candidate")"; then
        fallback="$candidate"
        break
      fi
    done
  fi
  valid_profile_pair "$profile" "$fallback" || die "logout requires a different authenticated fallback profile"
  controller_recover_logout_intents >/dev/null || die "an earlier logout operation still requires recovery"

  printf 'Checking logout safety on all configured nodes...\n'
  local_line=$("$0" __node logout-preflight "$profile" "$fallback") || die "local logout preflight failed"
  version=$(field_value "$local_line" version) || die "could not parse local helper version"
  [ "$version" = "$SCRIPT_VERSION" ] || die "local helper version mismatch"
  target_fp=$(field_value "$local_line" target_fp) || die "could not identify the selected profile"
  target_access=$(field_value "$local_line" target_access) || die "could not identify the selected profile access"
  fallback_fp=$(field_value "$local_line" fallback_fp) || die "could not identify the fallback profile"
  fallback_access=$(field_value "$local_line" fallback_access) || die "could not identify the fallback profile access"

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    line=$(remote_node_args "$index" logout-preflight "$profile" "$fallback") || die "logout preflight failed on ${REMOTE_LABELS[$index]}"
    version=$(field_value "$line" version) || die "could not parse ${REMOTE_LABELS[$index]} helper version"
    [ "$version" = "$SCRIPT_VERSION" ] || die "helper version mismatch on ${REMOTE_LABELS[$index]}"
    logout_preflight_matches "$line" "$target_fp" "$target_access" "$fallback_fp" "$fallback_access" || \
      die "profile credentials differ on ${REMOTE_LABELS[$index]}"
    index=$((index + 1))
  done

  printf 'Moving all devices to fallback profile %s...\n' "$fallback"
  controller_switch "$fallback" 1
  operation="logout_${profile}_$(date -u +%Y%m%dT%H%M%SZ)_$$"
  write_controller_logout_intent "$operation" staging "$profile" "$fallback" \
    "$target_fp" "$target_access" "$fallback_fp" "$fallback_access" || \
    die "could not create durable controller logout intent"

  printf 'Removing profile %s from SSH devices...\n' "$profile"
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if ! remote_node_args "$index" logout-stage "$operation" "$profile" "$fallback" >/dev/null; then
      if remote_node_args "$index" logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1; then
        staged_remote=$((staged_remote + 1))
      else
        abort_logout_stages "$operation" "$profile" "$local_staged" "$((index + 1))"
        die "logout failed on ${REMOTE_LABELS[$index]}"
      fi
    else
      staged_remote=$((staged_remote + 1))
    fi
    index=$((index + 1))
  done

  if ! "$0" __node logout-stage "$operation" "$profile" "$fallback" >/dev/null; then
    if "$0" __node logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1; then
      local_staged=1
    else
      abort_logout_stages "$operation" "$profile" 1 "$staged_remote"
      die "local logout failed"
    fi
  else
    local_staged=1
  fi

  if ! "$0" __node logout-verify "$operation" "$profile" "$fallback" >/dev/null; then
    abort_logout_stages "$operation" "$profile" "$local_staged" "$staged_remote"
    die "local logout verification failed"
  fi
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if ! remote_node_args "$index" logout-verify "$operation" "$profile" "$fallback" >/dev/null; then
      abort_logout_stages "$operation" "$profile" "$local_staged" "$staged_remote"
      die "logout verification failed on ${REMOTE_LABELS[$index]}"
    fi
    index=$((index + 1))
  done

  if ! write_controller_logout_intent "$operation" committing "$profile" "$fallback" \
      "$target_fp" "$target_access" "$fallback_fp" "$fallback_access"; then
    abort_logout_stages "$operation" "$profile" "$local_staged" "$staged_remote"
    die "could not commit durable controller logout intent"
  fi

  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    remote_node_args "$index" logout-commit "$operation" "$profile" "$fallback" >/dev/null 2>&1 || \
      { warn "logout cleanup pending on ${REMOTE_LABELS[$index]}"; commit_failed=1; }
    index=$((index + 1))
  done
  if [ "$commit_failed" -eq 0 ]; then
    "$0" __node logout-commit "$operation" "$profile" "$fallback" >/dev/null || commit_failed=1
  fi
  if [ "$commit_failed" -eq 1 ]; then
    printf 'operation=%s profile=%s fallback=%s state=partial-cleanup\n' "$operation" "$profile" "$fallback"
    return 2
  fi
  remove_controller_logout_intent "$operation" || {
    printf 'operation=%s profile=%s fallback=%s state=partial-cleanup\n' "$operation" "$profile" "$fallback"
    return 2
  }
  printf 'profile=%s fallback=%s account=%s state=logged-out\n' "$profile" "$fallback" "$target_fp"
}

controller_cleanup_logout_backups() {
  local transaction manifest operation profile fallback index
  local rc=0 found=0 cleaned=0 verified commit_failed
  ensure_dirs
  controller_recover_logout_intents >/dev/null || rc=2
  for transaction in "$LOGOUT_TXN_DIR/logout_"*; do
    [ -e "$transaction" ] || continue
    found=$((found + 1))
    if [ ! -d "$transaction" ] || [ -L "$transaction" ]; then
      warn "invalid local logout transaction: $transaction"
      rc=2
      continue
    fi
    operation=${transaction##*/}
    case "$operation" in ''|*[!0-9a-zA-Z_-]*) warn "invalid logout operation id"; rc=2; continue ;; esac
    manifest="$transaction/manifest"
    profile=$(sed -n 's/^profile=\([^ ]*\).*/\1/p' "$manifest" 2>/dev/null | head -n 1)
    fallback=$(sed -n 's/.*fallback=\([^ ]*\).*/\1/p' "$manifest" 2>/dev/null | head -n 1)
    if ! valid_profile_pair "$profile" "$fallback"; then
      warn "invalid logout cleanup manifest"
      rc=2
      continue
    fi

    verified=1
    "$0" __node logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1 || verified=0
    index=0
    while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
      remote_node_args "$index" logout-verify "$operation" "$profile" "$fallback" >/dev/null 2>&1 || verified=0
      index=$((index + 1))
    done
    if [ "$verified" -ne 1 ]; then
      warn "logout cleanup $operation is not globally verified; preserving every available backup"
      rc=2
      continue
    fi

    commit_failed=0
    index=0
    while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
      remote_node_args "$index" logout-commit "$operation" "$profile" "$fallback" >/dev/null 2>&1 || commit_failed=1
      index=$((index + 1))
    done
    if [ "$commit_failed" -eq 0 ]; then
      "$0" __node logout-commit "$operation" "$profile" "$fallback" >/dev/null 2>&1 || commit_failed=1
    fi
    if [ "$commit_failed" -eq 0 ]; then
      cleaned=$((cleaned + 1))
    else
      warn "logout cleanup $operation remains pending"
      rc=2
    fi
  done
  printf 'logout_cleanup=%s found=%s cleaned=%s\n' "$([ "$rc" -eq 0 ] && printf ok || printf partial)" "$found" "$cleaned"
  return "$rc"
}

print_status_line() {
  local label="$1"
  local line="$2"
  local active fp mode auth_mode cli credential access_fp expires_at
  active=$(field_value "$line" active 2>/dev/null || printf 'unknown')
  fp=$(field_value "$line" fingerprint 2>/dev/null || printf 'unknown')
  mode=$(field_value "$line" mode 2>/dev/null || printf 'unknown')
  auth_mode=$(field_value "$line" auth_mode 2>/dev/null || printf 'unknown')
  cli=$(field_value "$line" cli 2>/dev/null || printf 'unknown')
  credential=$(field_value "$line" credential 2>/dev/null || printf 'unknown')
  access_fp=$(field_value "$line" access_fp 2>/dev/null || printf 'unknown')
  expires_at=$(field_value "$line" expires_at 2>/dev/null || printf 'unknown')
  printf '%-9s %-8s %-12s %-6s %-10s %-13s %-12s %-12s %s\n' \
    "$label" "$active" "$fp" "$mode" "$auth_mode" "$cli" "$credential" "$access_fp" "$expires_at"
}

controller_status() {
  local line index
  printf '%-9s %-8s %-12s %-6s %-10s %-13s %-12s %-12s %s\n' \
    "NODE" "PROFILE" "ACCOUNT" "MODE" "AUTH" "CLI" "CREDENTIAL" "ACCESS" "EXPIRES"
  printf '%-9s %-8s %-12s %-6s %-10s %-13s %-12s %-12s %s\n' \
    "---------" "--------" "------------" "------" "----------" "-------------" "------------" "------------" "------------"
  if line=$("$0" __node status 2>/dev/null); then
    print_status_line "macbook" "$line"
  else
    print_status_line "macbook" "active=error fingerprint=error mode=error auth_mode=error cli=error credential=error access_fp=error expires_at=error"
  fi
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if line=$(remote_node "$index" status 2>/dev/null); then
      print_status_line "${REMOTE_LABELS[$index]}" "$line"
    else
      print_status_line "${REMOTE_LABELS[$index]}" "active=unreachable fingerprint=unknown mode=unknown auth_mode=unknown cli=unknown credential=unknown access_fp=unknown expires_at=unknown"
    fi
    index=$((index + 1))
  done
}

print_status_json_line() {
  local id="$1"
  local display_name="$2"
  local line="$3"
  local reachable="$4"
  local active fp auth_mode cli credential access_fp expires_at profile_json=null
  active=$(field_value "$line" active 2>/dev/null || printf 'unknown')
  fp=$(field_value "$line" fingerprint 2>/dev/null || printf 'unknown')
  auth_mode=$(field_value "$line" auth_mode 2>/dev/null || printf 'unknown')
  cli=$(field_value "$line" cli 2>/dev/null || printf 'unknown')
  credential=$(field_value "$line" credential 2>/dev/null || printf 'unknown')
  access_fp=$(field_value "$line" access_fp 2>/dev/null || printf 'unknown')
  expires_at=$(field_value "$line" expires_at 2>/dev/null || printf 'unknown')
  is_profile_name "$active" && profile_json="$active"
  jq -cn \
    --arg id "$id" --arg displayName "$display_name" --argjson profileID "$profile_json" \
    --arg accountFingerprint "$fp" --arg authMode "$auth_mode" --arg cliState "$cli" \
    --arg credential "$credential" --arg accessFingerprint "$access_fp" --arg expiresAt "$expires_at" \
    --argjson isReachable "$reachable" \
    '{id:$id,displayName:$displayName,profileID:$profileID,
      accountFingerprint:(if $accountFingerprint == "unknown" then null else $accountFingerprint end),
      authMode:(if $authMode == "unknown" then null else $authMode end),
      cliState:(if $cliState == "unknown" then null else $cliState end),
      credential:$credential,accessFingerprint:$accessFingerprint,expiresAt:$expiresAt,
      isReachable:$isReachable}'
}

controller_status_json() {
  local line index
  if line=$("$0" __node status 2>/dev/null); then
    print_status_json_line macbook "이 MacBook" "$line" true
  else
    print_status_json_line macbook "이 MacBook" "active=error" false
  fi
  index=0
  while [ "$index" -lt "${#REMOTE_TARGETS[@]}" ]; do
    if line=$(remote_node "$index" status 2>/dev/null); then
      print_status_json_line "${REMOTE_LABELS[$index]}" "${REMOTE_DISPLAY_NAMES[$index]}" "$line" true
    else
      print_status_json_line "${REMOTE_LABELS[$index]}" "${REMOTE_DISPLAY_NAMES[$index]}" "active=unreachable" false
    fi
    index=$((index + 1))
  done
}

print_usage_summary_json() {
  local id="$1" display="$2" reachable="$3" summary="${4:-}" error="${5:-}"
  if [ "$reachable" = true ]; then
    printf '%s\n' "$summary" | jq -ce --arg id "$id" --arg displayName "$display" \
      '{id:$id,displayName:$displayName,isReachable:true,summary:.}'
  else
    jq -cn --arg id "$id" --arg displayName "$display" --arg error "$error" \
      '{id:$id,displayName:$displayName,isReachable:false,summary:null,error:$error}'
  fi
}

controller_usage_summary() {
  local summary index=0 version error
  if summary=$("$0" __node usage-summary 2>&1); then
    print_usage_summary_json "macbook" "이 MacBook" true "$summary"
  else
    print_usage_summary_json "macbook" "이 MacBook" false "" "$summary"
  fi

  while [ "$index" -lt "${#REMOTE_LABELS[@]}" ]; do
    version=$(remote_node "$index" version 2>/dev/null || true)
    if [ "$version" != "$SCRIPT_VERSION" ]; then
      remote_install_helpers "$index" >/dev/null 2>&1 || true
    fi
    if summary=$(remote_node "$index" usage-summary 2>&1); then
      print_usage_summary_json "${REMOTE_LABELS[$index]}" "${REMOTE_DISPLAY_NAMES[$index]}" true "$summary"
    else
      error=${summary:-"사용량 수집기에 연결하지 못했습니다."}
      print_usage_summary_json "${REMOTE_LABELS[$index]}" "${REMOTE_DISPLAY_NAMES[$index]}" false "" "$error"
    fi
    index=$((index + 1))
  done
}

controller_accounts_json() {
  local first=1 profile
  if [ -f "$CONFIG_FILE" ] && [ ! -L "$CONFIG_FILE" ]; then
    jq -c '[.accounts[] | {id:.id,email:.email}]' "$CONFIG_FILE"
    return
  fi
  printf '['
  for profile in $(list_profile_ids); do
    [ "$first" -eq 1 ] || printf ','
    jq -cn --argjson id "$profile" --arg email "계정 $profile" '{id:$id,email:$email}'
    first=0
  done
  printf ']\n'
}

controller_test_device() {
  local wanted="$1" index=0 result
  case "$wanted" in ''|*[!a-z0-9-]*|-*) die "invalid device id" ;; esac
  while [ "$index" -lt "${#REMOTE_LABELS[@]}" ]; do
    if [ "${REMOTE_LABELS[$index]}" = "$wanted" ]; then
      result=$(remote_node "$index" version) || die "SSH connection failed for $wanted"
      [ "$result" = "$SCRIPT_VERSION" ] || die "helper version mismatch on $wanted: $result"
      printf 'device=%s result=ok version=%s\n' "$wanted" "$result"
      return
    fi
    index=$((index + 1))
  done
  die "device not found: $wanted"
}

controller_bootstrap_device() {
  local wanted="$1" index=0 found=-1 version active profile profile_file temporary metadata account_fp access_fp enrolled=0
  case "$wanted" in ''|*[!a-z0-9-]*|-*) die "invalid device id" ;; esac
  while [ "$index" -lt "${#REMOTE_LABELS[@]}" ]; do
    if [ "${REMOTE_LABELS[$index]}" = "$wanted" ]; then found=$index; break; fi
    index=$((index + 1))
  done
  [ "$found" -ge 0 ] || die "device not found: $wanted"
  index=$found
  require_refresh_helper
  active=$(detect_active_profile) || die "cannot identify the active Mac profile"

  prepare_remote_bootstrap_snapshot "$index" "$wanted"
  remote_install_helpers "$index" >/dev/null || die "helper installation failed for $wanted"
  version=$(remote_node "$index" version) || die "installed helper is unreachable on $wanted"
  [ "$version" = "$SCRIPT_VERSION" ] || die "helper version mismatch on $wanted: $version"

  for profile in $(list_profile_ids); do
    profile_file=$(profile_path "$profile")
    [ -e "$profile_file" ] || die "MacBook profile $profile is missing; refusing partial device enrollment"
    validate_secure_auth_file "$profile_file" full || die "MacBook profile $profile is insecure or is not full auth"
    metadata=$(helper_inspect "$profile_file" full) || die "could not inspect MacBook profile $profile"
    account_fp=$(metadata_field "$metadata" accountFingerprint) || die "could not identify MacBook profile $profile"
    access_fp=$(metadata_field "$metadata" accessFingerprint) || die "could not identify access token for profile $profile"
    temporary=$(mktemp "$STATE_ROOT/.bootstrap-access.$profile.XXXXXX") || die "could not prepare profile $profile for bootstrap"
    chmod 600 "$temporary"
    if ! "$NODE_BIN" "$REFRESH_HELPER" sanitize "$profile_file" "$temporary" >/dev/null || \
       ! validate_secure_auth_file "$temporary" access-only; then
      rm -f "$temporary"
      die "could not sanitize profile $profile for bootstrap"
    fi
    if ! remote_node_file "$index" "$temporary" install-access "$profile" "$account_fp" "$access_fp" >/dev/null; then
      rm -f "$temporary"
      die "could not install profile $profile on $wanted"
    fi
    rm -f "$temporary"
    enrolled=$((enrolled + 1))
  done

  [ "$enrolled" -gt 0 ] || die "no local account credentials are available for bootstrap"
  remote_node "$index" initialize "$active" >/dev/null || die "could not initialize profile $active on $wanted"
  remote_node "$index" verify "$active" >/dev/null || die "profile $active verification failed on $wanted"
  commit_remote_bootstrap_snapshot || die "could not finalize remote bootstrap recovery archive"
  printf 'device=%s result=ok active=%s profiles=%s version=%s\n' \
    "$wanted" "$active" "$enrolled" "$version"
}

application_running() {
  local name="$1"
  osascript -e "application \"$name\" is running" 2>/dev/null | grep -qx 'true'
}

running_inside_desktop_app() {
  local pid command parent iterations=0
  pid="$PPID"
  while [ "$pid" -gt 1 ] 2>/dev/null && [ "$iterations" -lt 20 ]; do
    command=$(ps -o command= -p "$pid" 2>/dev/null || true)
    case "$command" in
      *'/Applications/ChatGPT.app/'*|*'/Applications/Codex.app/'*) return 0 ;;
    esac
    parent=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)
    case "$parent" in
      ''|*[!0-9]*) break ;;
    esac
    pid="$parent"
    iterations=$((iterations + 1))
  done
  return 1
}

wait_for_app_exit() {
  local name="$1"
  local attempts=0
  while application_running "$name"; do
    attempts=$((attempts + 1))
    [ "$attempts" -lt 30 ] || return 1
    sleep 0.5
  done
}

stop_local_apps() {
  local chatgpt_running=0
  local codex_running=0
  local state="none"

  if application_running "ChatGPT"; then chatgpt_running=1; fi
  if application_running "Codex"; then codex_running=1; fi

  if [ "$chatgpt_running" -eq 1 ]; then
    state="chatgpt"
    osascript -e 'tell application "ChatGPT" to quit' >/dev/null 2>&1 || return 1
  fi
  if [ "$codex_running" -eq 1 ]; then
    if [ "$state" = "none" ]; then state="codex"; else state="$state,codex"; fi
    osascript -e 'tell application "Codex" to quit' >/dev/null 2>&1 || return 1
  fi

  [ "$chatgpt_running" -eq 0 ] || wait_for_app_exit "ChatGPT" || return 1
  [ "$codex_running" -eq 0 ] || wait_for_app_exit "Codex" || return 1
  printf '%s\n' "$state"
}

start_local_apps() {
  local state="$1"
  case ",$state," in
    *,chatgpt,*) open -a ChatGPT >/dev/null 2>&1 || warn "could not reopen ChatGPT" ;;
  esac
  case ",$state," in
    *,codex,*) open -a Codex >/dev/null 2>&1 || warn "could not reopen Codex" ;;
  esac
}

node_main() {
  local action="${1:-}"
  shift || true
  case "$action" in
    preflight) [ "$#" -eq 1 ] || die "node preflight requires a profile"; node_preflight "$1" ;;
    switch)
      [ "$#" -ge 1 ] && [ "$#" -le 2 ] || die "node switch requires a profile and optional restart flag"
      node_switch "$@"
      ;;
    verify) [ "$#" -eq 1 ] || die "node verify requires a profile"; node_verify "$1" ;;
    status) [ "$#" -eq 0 ] || die "node status takes no arguments"; node_status ;;
    stop-clients) [ "$#" -eq 0 ] || die "node stop-clients takes no arguments"; node_stop_clients ;;
    profile-map) [ "$#" -eq 0 ] || die "node profile-map takes no arguments"; node_profile_map ;;
    swap-profiles) [ "$#" -eq 0 ] || die "node swap-profiles takes no arguments"; node_swap_profiles ;;
    initialize) [ "$#" -eq 1 ] || die "node initialize requires a profile"; node_initialize "$1" ;;
    logout-preflight) [ "$#" -eq 2 ] || die "node logout-preflight requires profile and fallback"; node_logout_preflight "$1" "$2" ;;
    logout-stage) [ "$#" -eq 3 ] || die "node logout-stage requires operation, profile, and fallback"; node_logout_stage "$1" "$2" "$3" ;;
    logout-restore) [ "$#" -eq 2 ] || die "node logout-restore requires operation and profile"; node_logout_restore "$1" "$2" ;;
    logout-verify) [ "$#" -eq 3 ] || die "node logout-verify requires operation, profile, and fallback"; node_logout_verify "$1" "$2" "$3" ;;
    logout-commit) [ "$#" -eq 3 ] || die "node logout-commit requires operation, profile, and fallback"; node_logout_commit "$1" "$2" "$3" ;;
    install-access) [ "$#" -eq 3 ] || die "node install-access requires profile, account fingerprint, and access fingerprint"; node_install_access "$1" "$2" "$3" ;;
    inspect-access) [ "$#" -eq 2 ] || die "node inspect-access requires profile and access fingerprint"; node_inspect_access "$1" "$2" ;;
    usage-summary) [ "$#" -eq 0 ] || die "node usage-summary takes no arguments"; node_usage_summary ;;
    version) [ "$#" -eq 0 ] || die "node version takes no arguments"; printf '%s\n' "$SCRIPT_VERSION" ;;
    *) die "unknown internal action: $action" ;;
  esac
}

ensure_no_device_activation_transaction() {
  local first_entry entry base
  if [ ! -e "$DEVICE_ACTIVATION_TXN_DIR" ] && [ ! -L "$DEVICE_ACTIVATION_TXN_DIR" ]; then
    return 0
  fi
  [ -d "$DEVICE_ACTIVATION_TXN_DIR" ] && [ ! -L "$DEVICE_ACTIVATION_TXN_DIR" ] && \
    [ "$(file_owner_id "$DEVICE_ACTIVATION_TXN_DIR")" = "$(id -u)" ] && \
    [ "$(file_mode "$DEVICE_ACTIVATION_TXN_DIR")" = 700 ] || \
    die "unsafe device activation transaction directory"

  # A crash before the app's final intent rename can leave its exact UUID
  # staging name. The config is still disabled at that point, and this helper
  # owns the cross-process controller gate, so an owner-controlled regular
  # temp can be removed safely. Every other hidden entry remains fail-closed.
  for entry in "$DEVICE_ACTIVATION_TXN_DIR"/.*; do
    base=${entry##*/}
    case "$base" in .|..) continue ;; esac
    if [[ "$base" =~ ^\.[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}\.tmp$ ]]; then
      [ -f "$entry" ] && [ ! -L "$entry" ] && \
        [ "$(file_owner_id "$entry")" = "$(id -u)" ] || \
        die "unsafe device activation staging file"
      rm -f "$entry" || die "could not remove stale device activation staging file"
    fi
  done
  first_entry=$(find "$DEVICE_ACTIVATION_TXN_DIR" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null) || \
    die "could not inspect device activation transactions"
  [ -z "$first_entry" ] || \
    die "device activation verification is in progress; retry after it completes"
}

main() {
  local command="${1:-help}"
  local profile fallback="" restart_apps=1 selector="all" threshold="$DEFAULT_REFRESH_THRESHOLD" refresh_mode="" replace_account=0 rc=0
  local login_recovery="ok" logout_recovery="ok"

  if [ "$command" = "__node" ]; then
    shift
    node_main "$@"
    return
  fi

  if [ "$command" = version ] || [ "$command" = --version ]; then
    [ "$#" -eq 1 ] || die "$command takes no arguments"
    printf '%s\n' "$SCRIPT_VERSION"
    return
  fi

  case "$command" in
    accounts-json|help|-h|--help) ;;
    *) acquire_controller_lock ;;
  esac

  case "$command" in
    test-device|bootstrap-device)
      if [ "$#" -eq 2 ]; then load_configuration "$2"; else load_configuration; fi
      ;;
    *) load_configuration ;;
  esac

  # A prepared login import may already have published canonical auth. No
  # public command may inspect or mutate node state until that durable local
  # transaction has been deterministically recovered. import-login and
  # recover-controller run the same recovery in their own transaction flow.
  case "$command" in
    accounts-json|help|-h|--help|import-login|recover-controller) ;;
    *) controller_recover_login_transactions >/dev/null || \
         die "an interrupted login import must be recovered before another controller operation" ;;
  esac

  # The app briefly publishes an enabled SSH node before its post-enable
  # status verification. During that durable activation intent, read-only
  # status and recovery are allowed but every other controller mutation is
  # blocked, including commands launched by a second app process.
  case "$command" in
    accounts-json|help|-h|--help|status|status-json|usage-summary|recover-controller) ;;
    *) ensure_no_device_activation_transaction ;;
  esac

  if is_profile_name "$command"; then
    profile="$command"
    shift
    command="__direct-switch"
  fi

  case "$command" in
    __direct-switch) ;;
    switch)
      [ "$#" -ge 2 ] || die "switch requires a profile"
      profile="$2"
      validate_profile_name "$profile"
      shift 2
      ;;
    status)
      [ "$#" -eq 1 ] || die "status takes no arguments"
      controller_status
      return
      ;;
    status-json)
      [ "$#" -eq 1 ] || die "status-json takes no arguments"
      controller_status_json
      return
      ;;
    usage-summary)
      [ "$#" -eq 1 ] || die "usage-summary takes no arguments"
      controller_usage_summary
      return
      ;;
    accounts-json)
      [ "$#" -eq 1 ] || die "accounts-json takes no arguments"
      controller_accounts_json
      return
      ;;
    test-device)
      [ "$#" -eq 2 ] || die "test-device requires a device id"
      controller_test_device "$2"
      return
      ;;
    bootstrap-device)
      [ "$#" -eq 2 ] || die "bootstrap-device requires a device id"
      acquire_controller_lock
      controller_bootstrap_device "$2"
      release_controller_lock
      trap - EXIT HUP INT TERM
      return
      ;;
    recover-controller)
      [ "$#" -eq 1 ] || die "recover-controller takes no arguments"
      if ! controller_recover_login_transactions; then login_recovery="pending"; rc=2; fi
      if ! controller_recover_logout_intents; then logout_recovery="pending"; rc=2; fi
      printf 'login_recovery=%s logout_recovery=%s overall=%s\n' \
        "$login_recovery" "$logout_recovery" "$([ "$rc" -eq 0 ] && printf ok || printf pending)"
      release_controller_lock
      trap - EXIT HUP INT TERM
      return "$rc"
      ;;
    reconcile-profile-swap)
      [ "$#" -eq 3 ] || die "reconcile-profile-swap requires the two original account fingerprints"
      acquire_controller_lock
      controller_reconcile_profile_swap "$2" "$3"
      release_controller_lock
      trap - EXIT HUP INT TERM
      return
      ;;
    logout)
      [ "$#" -ge 2 ] || die "logout requires a profile"
      profile="$2"
      validate_profile_name "$profile"
      shift 2
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --fallback)
            [ "$#" -ge 2 ] || die "--fallback requires a profile"
            fallback="$2"
            validate_profile_name "$fallback"
            shift 2
            ;;
          *) die "unknown option: $1" ;;
        esac
      done
      acquire_controller_lock
      if controller_logout_profile "$profile" "$fallback"; then rc=0; else rc=$?; fi
      release_controller_lock
      trap - EXIT HUP INT TERM
      return "$rc"
      ;;
    cleanup-logouts)
      [ "$#" -eq 1 ] || die "cleanup-logouts takes no arguments"
      acquire_controller_lock
      if controller_cleanup_logout_backups; then rc=0; else rc=$?; fi
      release_controller_lock
      trap - EXIT HUP INT TERM
      return "$rc"
      ;;
    import-login)
      [ "$#" -ge 2 ] || die "import-login requires a profile"
      profile="$2"
      validate_profile_name "$profile"
      shift 2
      replace_account=0
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --replace-account) replace_account=1 ;;
          *) die "unknown option: $1" ;;
        esac
        shift
      done
      controller_import_login "$profile" "$replace_account"
      return
      ;;
    refresh-if-needed|refresh|sync-access)
      case "$command" in
        refresh-if-needed) refresh_mode="if-needed" ;;
        refresh) refresh_mode="force" ;;
        sync-access) refresh_mode="sync" ;;
      esac
      shift
      if [ "$#" -gt 0 ]; then
        if [ "$1" = all ] || is_profile_name "$1"; then selector="$1"; shift; fi
      fi
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --threshold-seconds)
            [ "$#" -ge 2 ] || die "--threshold-seconds requires a value"
            threshold="$2"
            shift 2
            ;;
          --no-restart-app) restart_apps=0; shift ;;
          --restart-app) restart_apps=1; shift ;;
          *) die "unknown option: $1" ;;
        esac
      done
      controller_refresh_command "$selector" "$refresh_mode" "$threshold" "$restart_apps"
      return $?
      ;;
    help|-h|--help)
      usage
      return
      ;;
    *)
      usage >&2
      die "unknown command: $command"
      ;;
  esac

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --restart-app) restart_apps=1 ;;
      --no-restart-app) restart_apps=0 ;;
      *) die "unknown option: $1" ;;
    esac
    shift
  done
  acquire_controller_lock
  controller_switch "$profile" "$restart_apps"
  release_controller_lock
  trap - EXIT HUP INT TERM
}

main "$@"
